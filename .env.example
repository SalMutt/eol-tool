# eol-tool configuration

# Cache directory (default: ~/.cache/eol-tool)
# EOL_TOOL_CACHE_DIR=/path/to/cache

# API server settings
# EOL_TOOL_HOST=0.0.0.0
# EOL_TOOL_PORT=8080

# Log level (DEBUG, INFO, WARNING, ERROR)
# EOL_TOOL_LOG_LEVEL=INFO

# ntfy notification settings
# EOL_TOOL_NTFY_URL=https://ntfy.sh
# EOL_TOOL_NTFY_TOPIC=
# EOL_TOOL_NTFY_TOKEN=

# Scheduled check settings
# EOL_TOOL_SCHEDULE_INTERVAL=24
# EOL_TOOL_RESULTS_DIR=./results
